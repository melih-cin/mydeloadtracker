# --- Supabase ---------------------------------------------------------------
# Project URL and anon (public) key from your Supabase project settings.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Anthropic --------------------------------------------------------------
# Used server-side only by the AI coach API route. Never expose this client-side.
ANTHROPIC_API_KEY=sk-ant-your-key
# Optional: override the model used by the coach.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Analytics (optional) ---------------------------------------------------
# PostHog product analytics. If unset, the app runs fine with analytics OFF.
# Create a free project at https://posthog.com and copy the Project API key.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
# Region host: https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU).
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Wearables (optional) ---------------------------------------------------
# Oura OAuth — register a free app at https://cloud.ouraring.com/oauth/applications
# with redirect URI <your-site>/api/wearables/oura/callback. Unset = "not configured".
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=
